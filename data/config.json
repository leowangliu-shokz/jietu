{
  "version": 2,
  "targets": [
    {
      "id": "shokz-home",
      "url": "https://shokz.com/",
      "label": "https://shokz.com/（首页）"
    },
    {
      "id": "shokz-products-nav",
      "url": "https://shokz.com/",
      "label": "https://shokz.com/（导航栏）",
      "captureMode": "shokz-products-nav",
      "fullPage": false
    },
    {
      "id": "shokz-headphones-accessories",
      "url": "https://shokz.com/collections/headphones-accessories",
      "label": "https://shokz.com/collections/headphones-accessories（集合页）"
    }
  ],
  "deviceProfiles": [
    {
      "id": "pc-default",
      "platform": "pc",
      "devicePresetId": "pc-hd",
      "enabled": true
    },
    {
      "id": "mobile-default",
      "platform": "mobile",
      "devicePresetId": "iphone-15",
      "enabled": true
    }
  ],
  "capturePlans": [
    {
      "id": "plan-shokz-home-pc-default",
      "targetId": "shokz-home",
      "deviceProfileId": "pc-default",
      "enabled": true
    },
    {
      "id": "plan-shokz-home-mobile-default",
      "targetId": "shokz-home",
      "deviceProfileId": "mobile-default",
      "enabled": true
    },
    {
      "id": "plan-shokz-products-nav-pc-default",
      "targetId": "shokz-products-nav",
      "deviceProfileId": "pc-default",
      "enabled": true
    },
    {
      "id": "plan-shokz-products-nav-mobile-default",
      "targetId": "shokz-products-nav",
      "deviceProfileId": "mobile-default",
      "enabled": true
    },
    {
      "id": "plan-shokz-headphones-accessories-pc-default",
      "targetId": "shokz-headphones-accessories",
      "deviceProfileId": "pc-default",
      "enabled": true
    },
    {
      "id": "plan-shokz-headphones-accessories-mobile-default",
      "targetId": "shokz-headphones-accessories",
      "deviceProfileId": "mobile-default",
      "enabled": true,
      "captureMode": "shokz-collection-page"
    }
  ],
  "intervalMinutes": 0,
  "fullPage": true,
  "waitAfterLoadMs": 2500,
  "dismissPopups": true,
  "lazyLoadScroll": true,
  "scrollStepMs": 350,
  "hideFixedElementsAfterFirstSegment": true,
  "maxFullPageHeight": 16000
}
