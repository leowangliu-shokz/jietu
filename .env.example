# Local-only secrets. Copy values into your user environment or an ignored .env file.

# Applitools Eyes visual compare
APPLITOOLS_API_KEY=
APPLITOOLS_APP_NAME=jietu
APPLITOOLS_BATCH_NAME=jietu-hourly
APPLITOOLS_BRANCH_NAME=main
APPLITOOLS_MATCH_LEVEL=Strict
# APPLITOOLS_SERVER_URL=https://eyes.applitools.com
# APPLITOOLS_RECORD_NEW_BASELINES_AS_CHANGES=0

# Generic external vision API fallback. Leave unset when using Applitools.
# VISION_COMPARE_ENDPOINT=
# VISION_COMPARE_API_KEY=
# VISION_COMPARE_BASE_URL=
# VISION_COMPARE_TIMEOUT_MS=30000
